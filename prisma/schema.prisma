generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senhaHash String
  funcao    String   @default("Usuário")
  status    String   @default("Ativo")
  createdAt DateTime @default(now())

  @@map("usuarios")
}

/// Empresas do grupo Ecotruck cadastradas no sistema (identifica de que lado
/// da nota — emitente ou destinatário — a empresa está, para aplicar o
/// regime tributário correto nas regras de crédito).
model Empresa {
  id                     Int      @id @default(autoincrement())
  cnpj                   String   @unique
  razaoSocial            String
  nomeFantasia           String   @default("")
  municipio              String   @default("")
  uf                     String
  regimeTributario       String // "Simples Nacional" | "Lucro Presumido" | "Lucro Real"
  cnaePrincipalCodigo    String   @default("")
  cnaePrincipalDescricao String   @default("")
  createdAt              DateTime @default(now())

  notasFiscais     NotaFiscal[]
  cnaesSecundarios CnaeSecundario[]
  objetoSocial     ObjetoSocialItem[]

  @@map("empresas")
}

/// CNAEs secundários registrados na Receita Federal para o CNPJ da empresa.
model CnaeSecundario {
  id        Int     @id @default(autoincrement())
  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  codigo    String // ex: "45.20-0-07"
  descricao String

  @@unique([empresaId, codigo])
  @@map("cnaes_secundarios")
}

/// Itens do objeto social conforme o Estatuto/Contrato Social (podem diferir
/// dos CNAEs registrados na Receita Federal — refletem o texto societário).
model ObjetoSocialItem {
  id        Int      @id @default(autoincrement())
  empresaId Int
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  descricao String
  origem    String   @default("") // ex: "Alteração 5.1 do Estatuto Social"
  createdAt DateTime @default(now())

  @@map("objeto_social_itens")
}

model NotaFiscal {
  id                Int      @id @default(autoincrement())
  empresaId         Int?
  empresa           Empresa? @relation(fields: [empresaId], references: [id])
  chaveAcesso       String   @unique
  numero            String
  serie             String
  dataEmissao       DateTime
  tpNF              Int // 0 = entrada, 1 = saída
  idDest            Int // 1 interna, 2 interestadual, 3 exterior
  finNFe            Int // 1 normal, 2 complementar, 3 ajuste, 4 devolução
  naturezaOperacao  String   @default("")
  emitCnpj          String
  emitNome          String
  emitUf            String
  emitCrt           Int // 1 Simples Nacional, 2 Simples excesso sublimite, 3 Regime Normal
  destCnpj          String
  destNome          String
  destUf            String
  valorProdutos     Float
  valorIcms         Float    @default(0)
  valorIpi          Float    @default(0)
  valorPis          Float    @default(0)
  valorCofins       Float    @default(0)
  valorTotal        Float
  xmlBruto          String
  arquivoPdf        Bytes? // PDF original (DANFE), quando a nota foi importada em PDF — null para notas importadas via XML
  status            String   @default("Processada") // Processada | Erro
  erroProcessamento String?
  createdAt         DateTime @default(now())

  itens ItemNotaFiscal[]

  @@map("notas_fiscais")
}

model ItemNotaFiscal {
  id             Int        @id @default(autoincrement())
  notaFiscalId   Int
  notaFiscal     NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  numeroItem     Int
  codigoProduto  String
  descricao      String
  ncm            String
  cest           String     @default("")
  cfop           String
  unidade        String
  quantidade     Float
  valorUnitario  Float
  valorProduto   Float

  origem         Int        @default(0)
  cst            String     @default("") // regime normal
  csosn          String     @default("") // Simples Nacional
  modBC          Int        @default(0)
  icmsBase       Float      @default(0)
  icmsAliquota   Float      @default(0)
  icmsValor      Float      @default(0)
  icmsStBase     Float      @default(0)
  icmsStAliquota Float      @default(0)
  icmsStValor    Float      @default(0)
  fcpAliquota    Float      @default(0)

  ipiCst      String @default("")
  ipiBase     Float  @default(0)
  ipiAliquota Float  @default(0)
  ipiValor    Float  @default(0)

  pisCst      String @default("")
  pisBase     Float  @default(0)
  pisAliquota Float  @default(0)
  pisValor    Float  @default(0)

  cofinsCst      String @default("")
  cofinsBase     Float  @default(0)
  cofinsAliquota Float  @default(0)
  cofinsValor    Float  @default(0)

  createdAt DateTime @default(now())

  validacoes  ValidacaoClassificacao[]
  creditos    CreditoTributario[]
  simulacoes  SimulacaoReforma[]

  @@map("itens_nota_fiscal")
}

model ValidacaoClassificacao {
  id               Int            @id @default(autoincrement())
  itemNotaFiscalId Int
  item             ItemNotaFiscal @relation(fields: [itemNotaFiscalId], references: [id], onDelete: Cascade)
  regra            String // código da regra, ex: "CFOP_UF_MISMATCH"
  severidade       String // "erro" | "aviso"
  mensagem         String
  createdAt        DateTime       @default(now())

  @@map("validacoes_classificacao")
}

model CreditoTributario {
  id               Int            @id @default(autoincrement())
  itemNotaFiscalId Int
  item             ItemNotaFiscal @relation(fields: [itemNotaFiscalId], references: [id], onDelete: Cascade)
  tipoImposto      String // "ICMS" | "PIS" | "COFINS"
  elegivel         Boolean
  valorCredito     Float          @default(0)
  motivo           String
  createdAt        DateTime       @default(now())

  @@map("creditos_tributarios")
}

model SimulacaoReforma {
  id               Int            @id @default(autoincrement())
  itemNotaFiscalId Int
  item             ItemNotaFiscal @relation(fields: [itemNotaFiscalId], references: [id], onDelete: Cascade)
  anoReferencia    Int
  categoriaAliquota String // "padrao" | "reduzida40" | "reduzida60" | "isenta"
  aliquotaCbs      Float
  aliquotaIbs      Float
  aliquotaIs       Float
  valorCbs         Float
  valorIbs         Float
  valorIs          Float
  valorAtual       Float // carga hoje: ICMS + IPI + PIS + COFINS do item
  valorReforma     Float // CBS + IBS + IS do item, já ponderado pelo blend de transição do ano
  delta            Float // valorReforma - valorAtual
  createdAt        DateTime       @default(now())

  @@map("simulacoes_reforma")
}

/// Tabela de referência editável: mapeia prefixos de NCM para a categoria de
/// alíquota (padrão, reduzida ou isenta) e sinaliza produtos sujeitos ao
/// Imposto Seletivo. Editável via /configuracao porque a regulamentação da
/// reforma (Anexos da LC 214/2025) ainda está sendo detalhada.
model TabelaAliquota {
  id               Int      @id @default(autoincrement())
  prefixoNcm       String // ex: "1006" (arroz); "" = categoria padrão (catch-all)
  descricao        String
  categoria        String // "padrao" | "reduzida40" | "reduzida60" | "isenta"
  seletivo         Boolean  @default(false)
  aliquotaSeletivo Float    @default(0)
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("tabela_aliquotas")
}

/// Configuração global (linha única) das alíquotas padrão de CBS/IBS
/// enquanto a definição final do Senado não é publicada.
model ConfiguracaoReforma {
  id                Int      @id @default(autoincrement())
  aliquotaPadraoCbs Float    @default(8.8)
  aliquotaPadraoIbs Float    @default(17.7)
  updatedAt         DateTime @updatedAt

  @@map("configuracao_reforma")
}

// ---------------------------------------------------------------------------
// Retenções na Fonte (IRRF, PIS/COFINS/CSLL, INSS, ISS) por item da lista de
// serviços da LC 116/2003. Fonte: planilha do escritório
// (prisma/data/retencoes-fonte-lc116.xlsx), importada via `npm run import:retencoes`.
// ---------------------------------------------------------------------------

/// Catálogo de itens/subitens da lista de serviços da LC 116/2003, com as
/// regras de retenção federal (PIS/COFINS/CSLL = "PCC" e IRRF) e previdenciária
/// (INSS). Um mesmo subitem oficial pode aparecer desdobrado em variantes
/// (sufixo "a"/"b"/"-A"/"-B") quando a fonte identifica tratamentos tributários
/// diferentes para hipóteses distintas do mesmo subitem.
model ItemServicoLC116 {
  id             Int    @id @default(autoincrement())
  codigo         String @unique // ex: "7.05", "7.09 a", "12.13-A"
  codigoBase     String // ex: "7.05", "7.09", "12.13" — sem sufixo, usado para casar com ISS/INSS
  itemGrupo      String // ex: "7" — número do grupo/capítulo da lista
  grupoDescricao String @default("")
  descricao      String

  pis               String // "SIM" | "NAO" | "SIM/NAO" | "NAO/SIM" | "NA"
  cofins            String
  csll              String
  irrf15            String // IRRF 1,5% (serviços profissionais, rol taxativo)
  irrf10            String // IRRF 1,0% (limpeza, conservação, segurança, vigilância, locação de mão de obra)
  observacaoFederal String @default("")

  inss           String @default("NA") // "SIM" | "NAO" | "NA" (segue a base pela cessão de mão de obra)
  observacaoInss String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("itens_servico_lc116")
}

/// Alíquota e obrigatoriedade de retenção de ISS por município (legislação do
/// município do TOMADOR do serviço) e por item da lista de serviços.
model RetencaoIssMunicipio {
  id         Int    @id @default(autoincrement())
  municipio  String
  codigoBase String // casa com ItemServicoLC116.codigoBase
  descricao  String @default("")
  aliquota   Float?
  retencao   String // "SIM" | "NAO" | "NA"
  observacao String @default("")

  @@unique([municipio, codigoBase])
  @@index([municipio])
  @@map("retencoes_iss_municipio")
}

/// Particularidades e obrigações acessórias por município (ex: cadastro CENE/
/// CPOM de prestadores não estabelecidos) que afetam a obrigação de retenção.
model MunicipioParticularidade {
  id              Int    @id @default(autoincrement())
  municipio       String @unique
  particularidade String

  @@map("municipio_particularidades")
}

/// Tabelas do Simples Nacional (Anexo III — serviços em geral; Anexo IV —
/// serviços do §5º-C art. 18 LC 123/2006, sem partilha de INSS) por faixa de
/// receita bruta acumulada em 12 meses.
model SimplesNacionalFaixa {
  id              Int    @id @default(autoincrement())
  anexo           String // "III" | "IV"
  faixaMin        Float
  faixaMax        Float?
  aliquotaNominal Float
  irpj            Float
  csll            Float
  cofins          Float
  pis             Float
  iss             Float

  @@map("simples_nacional_faixas")
}

/// Nota fiscal de serviço (NFS-e/NFCom) importada em PDF, usada para
/// alimentar a apuração de Retenções na Fonte. Documentos no padrão nacional
/// (DANFSe) e NFCom têm extração confiável; layouts próprios de município
/// ("municipal_generico") são sempre importados como "Necessita revisão".
model NotaServico {
  id                Int      @id @default(autoincrement())
  arquivoOrigem     String
  tipoDocumento     String // "danfse_nacional" | "nfcom" | "municipal_generico"
  status            String   @default("Necessita revisão") // "Necessita revisão" | "Confirmada"

  chaveAcesso       String?
  numero            String   @default("")
  dataEmissao       DateTime?
  competencia       String   @default("")

  prestadorCnpj            String  @default("")
  prestadorNome             String  @default("")
  prestadorMunicipio        String  @default("")
  prestadorSimplesNacional  Boolean @default(false)

  tomadorCnpj       String  @default("")
  tomadorNome       String  @default("")
  tomadorMunicipio  String  @default("")

  codigoTributacaoNacional String @default("")
  itemServicoCodigoBase    String?

  descricaoServico  String  @default("")
  valorServico      Float?
  aliquotaIss       Float?
  issRetido         Boolean?
  valorIss          Float?
  irrfDeclarado     Float?
  pccDeclarado      Float?
  valorLiquido      Float?

  camposNaoEncontrados String[] @default([])
  textoExtraido        String   @default("")
  arquivoPdf           Bytes? // PDF original, quando a nota foi importada em PDF

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notas_servico")
}
